{
  "name": "@corner-gym/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && concurrently -k \"pnpm --filter @corner-gym/ui dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron --no-sandbox dist/main.js\"",
    "build": "tsc && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@corner-gym/engine": "workspace:*",
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
